# Environment variables for local development.
#
# 1. Copy this file: cp .env.example .env
# 2. Fill in real values in .env
# 3. Never commit .env to version control — it is listed in .gitignore
#
# Docker Compose reads .env automatically from the project root.
# Ref: https://docs.docker.com/compose/how-tos/environment-variables/envvars-precedence/

# ---------------------------------------------------------------------------
# PostgreSQL password
# Used by the db service (POSTGRES_PASSWORD) and the model service
# (DATABASE_URL connection string). Both must match.
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me-postgres-password
