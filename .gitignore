.DS_Store
# Word/Excel temp lock files
~$*

# Local environment secrets — never commit real credentials
.env

# IDE / editor configs — local machine only
.vscode/
.idea/
*.code-workspace

# MCP server config (local dev tool)
.mcp.json

# AI assistant personal configs — never commit
.claude/

# Python
__pycache__/
*.pyc
*.pyo

# Media and binary test data — store externally, not in git
media/
results_masking/

# Photo / image files
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.tif
*.webp
*.svg
*.ico

# AI-generated document folder (thesis chapters, prompts, scripts)
document/

# AI-generated wiki / docs
docs/wiki/

# Miscellaneous planning markdown files
plan.md
plan_chapter.md


latex_doc